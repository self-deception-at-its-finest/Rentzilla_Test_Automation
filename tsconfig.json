{
  "compilerOptions": {
    "target": "ESNext",
    "module": "commonjs",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "resolveJsonModule": true,
    "noUnusedLocals": true, 
    "noUnusedParameters": true,
    "baseUrl": ".",
    "paths": {
      "@fixtures/*": ["fixtures/*"],
      "@utils/*": ["utils/*"],
      "@constants/*": ["constants/*"],
      "@pages/*": ["pages/*"],
      "@custom-types/*": ["types/*"],
      "@config/*": ["config/*"],
      "@flows/*": ["flows/*"],
      "@components/*": ["components/*"]
    }
  },
  "include": [
    "playwright.config.ts",
    "components",
    "fixtures",
    "pages",
    "tests",
    "constants",
    "utils",
    "types",
    "flows",
    "config"
  ]
}
